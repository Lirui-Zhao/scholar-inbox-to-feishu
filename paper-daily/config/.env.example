# First-run tip: you don't need to edit this file by hand.
# Just type `/paper-daily` once — it will prompt you for the login URL
# the first time and write `.env` for you (with 0600 permissions).
# This template exists for headless setup or manual editing if you prefer.
#
# .env is git-ignored by convention; never commit your sha_key.

# Option A — paste the hex token directly (preferred):
SCHOLAR_INBOX_SHA_KEY=

# Option B — paste the full magic-link URL from your Scholar Inbox login email:
#   https://www.scholar-inbox.com/login?sha_key=abc123...
# If both are set, SCHOLAR_INBOX_SHA_KEY wins.
# SCHOLAR_INBOX_LOGIN_URL=

# ── Summary-card receiver (optional) ──────────────────────────────────────────
# Where the daily summary card goes. Read from here OR from the environment.
# Default = the authenticated user's own DM. Override with a user open_id (ou_...)
# or a group chat id (oc_...).
# FEISHU_RECEIVER=oc_xxxxxxxxxxxxxxxx

# ── Tunable paths / behavior (OPTIONAL — set as ENVIRONMENT VARIABLES) ─────────
# These are NOT read from this file; export them in your shell / cron env to
# override the built-in defaults. Listed here for reference. See README → Configuration.
#   PAPER_DAILY_STATE_DIR      default ~/.local/share/paper-daily   (seen/cookies/folder_state)
#   PAPER_DAILY_WORKDIR_ROOT   default ~/papers-daily               (per-day workdir: PDFs/figures/plan-JSON)
#   PAPER_DAILY_CONFIG_DIR     default ~/.claude/skills/paper-daily/config  (this .env's location)
#   FEISHU_ROOT_FOLDER         default paper-daily                  (Feishu cloud root folder name)
#   PAPER_DAILY_LIMIT          default 8                            (papers/day; CLI --limit wins)
#   PAPER_DAILY_PARALLEL       default 4                            (concurrency hint)
